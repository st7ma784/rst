# Copy to .env and fill in your values.
# docker compose reads .env automatically.

# ── Image registry & tag ──────────────────────────────────────────────────────
REGISTRY=             # e.g. ghcr.io/your-org/ (include trailing slash)
TAG=latest

# ── Backend ───────────────────────────────────────────────────────────────────
BACKEND_TYPE=pythonv2   # pythonv2 | cuda | rst
BACKEND_PORT=8000

# Comma-separated list of origins allowed by CORS (frontend URL)
CORS_ORIGINS=http://localhost

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_PORT=8080
